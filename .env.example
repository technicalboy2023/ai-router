# OpenRouter Keys (up to 20 numbered slots)
OPENROUTER_KEY_1=sk-or-v1-...
# OPENROUTER_KEY_2=sk-or-v1-...
# OPENROUTER_KEYS=sk-or-v1-aaa,sk-or-v1-bbb

# Gemini Keys
# GEMINI_KEY_1=AIza...
# GEMINI_KEYS=AIza...,AIza...

# Groq Keys
# GROQ_KEY_1=gsk_...
# GROQ_KEYS=gsk_...,gsk_...

# Ollama Keys
# OLLAMA_KEY_1=ollama_bearer_token...
# OLLAMA_KEYS=token1,token2

# Router Auth (optional)
# AUTH_TOKEN=your-secret-bearer-token

# Server (Render sets PORT automatically)
# PORT=8000
