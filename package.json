{
  "name": "universal-ai-router",
  "version": "1.0.0",
  "description": "Production-grade Universal AI Router — multi-provider, multi-router LLM gateway with OpenAI compatibility",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "ai-router": "./bin/ai-router.js"
  },
  "scripts": {
